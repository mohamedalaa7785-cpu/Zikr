# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Use the Supabase anon JWT/public API key for browser + REST requests. Do not commit real keys.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database
DATABASE_URL=

# Site URL
NEXT_PUBLIC_SITE_URL=https://your-domain.example
# Must be the app route below, not /api/auth/callback.
AUTH_CALLBACK_URL=https://your-domain.example/auth/callback

# Optional content integrations (Phase 2+)
QURAN_API_BASE_URL=
QURAN_AUDIO_CDN_URL=
HADITH_API_BASE_URL=
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
YOUTUBE_PLAYLIST_ID=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS S3
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_S3_REGION=
