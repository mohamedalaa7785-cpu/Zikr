# ==============================================================================
# CRITICAL: SUPABASE CONFIGURATION (Required for all environments)
# ==============================================================================

# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (KEEP SECRET - server-side only)
# Found in Supabase Settings > API > Service Role Key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database connection string for Drizzle migrations
# Format: postgresql://user:password@host/database
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ==============================================================================
# VERCEL/SITE CONFIGURATION (Required for deployment)
# ==============================================================================

# Your site's public URL (used for OAuth callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
AUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# ==============================================================================
# OPTIONAL: CONTENT & INTEGRATIONS
# ==============================================================================

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google OAuth (optional - enables OAuth login if configured)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# YouTube integration (optional)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
YOUTUBE_PLAYLIST_ID=

# Quran & Hadith APIs (optional)
QURAN_API_BASE_URL=
QURAN_AUDIO_CDN_URL=
HADITH_API_BASE_URL=

# AWS S3 (optional)
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_S3_REGION=

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================
#
# 1. SUPABASE SETUP:
#    - Sign up at https://supabase.com
#    - Create a new project
#    - Copy the Project URL and Anon Key from Settings > API
#    - Get the Service Role Key (keep it secret!)
#    - Create a database connection string in format shown above
#
# 2. VERCEL ENVIRONMENT VARIABLES:
#    - Add all REQUIRED variables above to your Vercel project dashboard
#    - Go to Settings > Environment Variables in your Vercel project
#    - Add: NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY,
#      SUPABASE_SERVICE_ROLE_KEY, DATABASE_URL, NEXT_PUBLIC_SITE_URL,
#      AUTH_CALLBACK_URL
#
# 3. GITHUB SYNC:
#    - Connect your GitHub repo to Vercel
#    - Push changes to main branch (or configured branch)
#    - Vercel will automatically deploy
#
# 4. DATABASE SETUP:
#    - Run: pnpm db:migrate:supabase
#    - This applies all SQL migrations from supabase/migrations/
#    - Migrations include schema, RLS policies, and data setup
#
# 5. DEPLOYMENT VALIDATION:
#    - Run: pnpm deploy:check
#    - Fix any ❌ failures before deploying
#    - ⚠️  warnings can usually be ignored for basic functionality
#
